POSTGRES_USER=recipe_admin
POSTGRES_PASSWORD=replace-with-a-strong-local-password
POSTGRES_DB=recipe_platform
CATALOGUE_V3_DB=recipe_catalogue_v3

DATABASE_URL=postgresql+psycopg2://recipe_admin:replace-with-a-strong-local-password@localhost:5433/recipe_platform
CATALOGUE_V3_DATABASE_URL=postgresql+psycopg2://recipe_admin:replace-with-a-strong-local-password@localhost:5433/recipe_catalogue_v3
SQLALCHEMY_ECHO=false

# Required for curator write-back, review submission, and RAG endpoints.
API_ADMIN_TOKEN=replace-with-a-long-random-admin-token

# Optional LLM/RAG settings
GEMINI_API_KEY=
GEMINI_INPUT_COST_PER_1K=0
GEMINI_OUTPUT_COST_PER_1K=0

# API settings
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Validation alerting
SLACK_WEBHOOK_URL=
PAGERDUTY_ROUTING_KEY=
PAGERDUTY_SEVERITY=critical
CRITICAL_FAILURE_ALERT_THRESHOLD=5
CRITICAL_FAILURE_WINDOW_MINUTES=60

# Scraper identity
RECIPE_PIPELINE_USER_AGENT=RecipeIntelligencePlatform/1.0 (+mailto:your-email@example.com)
